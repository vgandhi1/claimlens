# ── Copy to .env and fill in values. Never commit .env ──

# ── Application ──
CLAIMLENS_ENVIRONMENT=development

# ── Authentication (optional in dev; required in production) ──
# CLAIMLENS_API_KEY=

# ── Model artifacts ──
CLAIMLENS_MODEL_PATH=models/anomaly_clf.joblib
CLAIMLENS_METRICS_PATH=models/metrics.json
CLAIMLENS_MANIFEST_PATH=models/manifest.json

# ── Inference tuning ──
CLAIMLENS_MAX_NARRATIVE_LENGTH=8192
# Flag predictions below this confidence for human review (default: 0.55)
CLAIMLENS_CONFIDENCE_THRESHOLD=0.55

# ── QualityMind handoff (optional — for POST /handoff/execute) ──
QUALITYMIND_BASE_URL=http://localhost:8000
# QUALITYMIND_API_KEY=
